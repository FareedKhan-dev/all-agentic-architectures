# Keep the build context small + clean.

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets — NEVER let .env into the image
.env
.env.*
!.env.example

# Notebook checkpoints
.ipynb_checkpoints/

# Built site (regenerated by mkdocs)
site/

# Git
.git/
.gitignore

# CI artefacts
.github/
.pre-commit-config.yaml
